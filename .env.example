# ========================================
# AIBTC.Studio - Environment Configuration
# ========================================

# Required: AI Models
ANTHROPIC_API_KEY=          # Claude for reasoning, scoring, captioning
GEMINI_API_KEY=             # Google AI for image generation

# Optional: AI Gateway (for model routing/fallbacks)
AI_GATEWAY_API_KEY=

# Server
PORT=3000
TEST_MODE=false             # Set to true for faster timers + single image variants

# ========================================
# Optional: Publishing to X/Twitter
# ========================================
TWITTER_POSTING_ENABLED=false
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_USERNAME=

# ========================================
# Optional: CDN (Cloudflare R2)
# Enables edge-cached media serving
# ========================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ========================================
# Optional: Backup (Postgres)
# Encrypted state backup
# ========================================
DATABASE_URL=
