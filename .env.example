# ========================================
# AIBTC Media - Environment Configuration
# ========================================

# Required: AI Models
ANTHROPIC_API_KEY=          # Claude for reasoning, scoring, captioning
GEMINI_API_KEY=             # Google AI for image generation

# Optional: AI Gateway (for model routing/fallbacks)
AI_GATEWAY_API_KEY=

# Server
PORT=3000
TEST_MODE=false             # Set to true for faster timers + single image variants

# ========================================
# Optional: Publishing to X/Twitter
# ========================================
TWITTER_POSTING_ENABLED=false
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_USERNAME=

# ========================================
# Optional: RSS Feed Sources
# CoinDesk and The Defiant are enabled by default
# ========================================
COINDESK_ENABLED=true
COINDESK_FEED_URL=https://www.coindesk.com/arc/outboundfeeds/rss/
COINDESK_MAX_ARTICLES=30
THEDEFIANT_ENABLED=true
THEDEFIANT_FEED_URL=https://thedefiant.io/feed
THEDEFIANT_MAX_ARTICLES=30

# ========================================
# Optional: Bitcoin Magazine RSS
# ========================================
BTCMAG_ENABLED=true
BTCMAG_FEED_URL=https://bitcoinmagazine.com/feed
BTCMAG_MAX_ARTICLES=30

# ========================================
# Optional: CDN (Cloudflare R2)
# Enables edge-cached media serving
# ========================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ========================================
# Optional: Backup (Postgres)
# Encrypted state backup
# ========================================
DATABASE_URL=

# ========================================
# Optional: Bitcoin Ordinals Inscription
# Inscribes each cartoon as a Bitcoin Ordinal for on-chain provenance
# ========================================
INSCRIPTION_ENABLED=false       # Set to true to enable inscription
ORDINALS_NETWORK=testnet        # testnet or mainnet
ORDINALS_MNEMONIC=              # BIP39 mnemonic for inscription wallet
ORDINALS_MAX_FEE_RATE=3         # Max fee rate in sat/vB
ORDINALS_MAX_COST_USD=2         # Max cost per inscription in USD
ORDINALS_MEMPOOL_API=https://mempool.space/testnet4/api  # Mempool API endpoint
